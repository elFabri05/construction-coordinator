# Copy to apps/api/.env for local development.
DATABASE_URL=postgresql://construct:construct@localhost:5432/construct
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-too-in-production
REDIS_URL=redis://localhost:6379

# S3-compatible storage (Cloudflare R2 by default — see apps/api/.env.example
# for AWS S3 / MinIO variants).
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=construct-coordinator
S3_ACCESS_KEY_ID=change-me
S3_SECRET_ACCESS_KEY=change-me
S3_FORCE_PATH_STYLE=true

# Mobile (apps/mobile/.env): where Expo should reach the API.
# Use your machine's LAN IP when testing on a physical device.
EXPO_PUBLIC_API_URL=http://localhost:3000
