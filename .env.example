# Copy to apps/api/.env for local development.
DATABASE_URL=postgresql://construct:construct@localhost:5432/construct
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-too-in-production
REDIS_URL=redis://localhost:6379

# Mobile (apps/mobile/.env): where Expo should reach the API.
# Use your machine's LAN IP when testing on a physical device.
EXPO_PUBLIC_API_URL=http://localhost:3000
