generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  owner
  superuser
  member
}

enum MembershipStatus {
  invited
  active
}

enum TaskStatus {
  pending
  in_progress
  blocked
  done
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  // Null means "placeholder" — the user was invited by email but has not
  // registered yet. Registration with that email claims the account.
  passwordHash String?  @map("password_hash")
  name         String
  createdAt    DateTime @default(now()) @map("created_at")

  ownedProjects      Project[]    @relation("ProjectOwner")
  memberships        Membership[]
  sentInvites        Membership[] @relation("InvitedBy")
  updatedGuidelines  Guideline[]  @relation("GuidelineUpdatedBy")
  createdTasks       Task[]       @relation("TaskCreatedBy")
  submissions        Submission[]

  @@map("users")
}

model Project {
  id        String   @id @default(uuid())
  name      String
  goal      String
  ownerId   String   @map("owner_id")
  createdAt DateTime @default(now()) @map("created_at")

  owner       User         @relation("ProjectOwner", fields: [ownerId], references: [id])
  memberships Membership[]
  guideline   Guideline?
  tasks       Task[]
  submissions Submission[]

  @@map("projects")
}

// One evolving guideline document per project (projectId is unique), written
// via upsert. Version history is a likely Phase 5+ feature — nothing here
// should make adding a history table hard later, but it is deliberately not
// built now.
model Guideline {
  id          String   @id @default(uuid())
  projectId   String   @unique @map("project_id")
  content     String
  updatedById String   @map("updated_by")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  updatedBy User    @relation("GuidelineUpdatedBy", fields: [updatedById], references: [id])

  @@map("guidelines")
}

model Task {
  id            String     @id @default(uuid())
  projectId     String     @map("project_id")
  title         String
  description   String     @default("")
  status        TaskStatus @default(pending)
  sequenceOrder Int        @map("sequence_order")
  createdById   String     @map("created_by")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy   User         @relation("TaskCreatedBy", fields: [createdById], references: [id])
  submissions Submission[]

  @@index([projectId, sequenceOrder])
  @@map("tasks")
}

// Field-work evidence attached to a task: photo and/or comment. This is the
// primary input the Phase 4+ AI layer will reason over, so:
// - rows are IMMUTABLE once created (no update path; corrections are new
//   submissions) to keep the audit trail honest, and
// - deletion is soft (deletedAt) — never hard-delete, the row may be
//   referenced by AI suggestion history later.
// Only object KEYS are stored; signed read URLs are generated on demand.
// Submissions are always task-scoped — a "general project comment" is a
// possible Phase 5+ feature, deliberately not built now.
model Submission {
  id           String    @id @default(uuid())
  taskId       String    @map("task_id")
  projectId    String    @map("project_id")
  userId       String    @map("user_id")
  comment      String?
  photoKey     String?   @map("photo_key")
  thumbnailKey String?   @map("photo_thumbnail_key")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  task    Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([taskId, createdAt])
  @@map("submissions")
}

model Membership {
  id          String           @id @default(uuid())
  projectId   String           @map("project_id")
  userId      String           @map("user_id")
  role        MembershipRole
  status      MembershipStatus
  invitedById String?          @map("invited_by")
  createdAt   DateTime         @default(now()) @map("created_at")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedBy User?   @relation("InvitedBy", fields: [invitedById], references: [id])

  @@unique([projectId, userId])
  @@map("memberships")
}
