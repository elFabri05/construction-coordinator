DATABASE_URL=postgresql://construct:construct@localhost:5432/construct
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-too-in-production
REDIS_URL=redis://localhost:6379
PORT=3000

# AI submission-review queue: submissions landing on the same task within this
# window are batched into a single review job (see apps/ai-worker).
SUBMISSION_REVIEW_DEBOUNCE_MS=120000

# Transactional email (invites). Leave RESEND_API_KEY unset in dev to log
# emails instead of sending them.
RESEND_API_KEY=
EMAIL_FROM="Construct Coordinator <onboarding@resend.dev>"
# Public base URL of this API — used to build invite links (/invite landing page).
APP_PUBLIC_URL=http://localhost:3000

# S3-compatible object storage for submission photos.
# Cloudflare R2 (default choice): S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com, S3_REGION=auto
# AWS S3: S3_ENDPOINT=https://s3.<region>.amazonaws.com, S3_REGION=<region>, S3_FORCE_PATH_STYLE=false
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=construct-coordinator
S3_ACCESS_KEY_ID=change-me
S3_SECRET_ACCESS_KEY=change-me
S3_FORCE_PATH_STYLE=true
