# Same database and Redis as apps/api — the worker reads the shared Prisma
# schema (apps/api/prisma/schema.prisma) and consumes the submission-review
# queue that the API produces.
DATABASE_URL=postgresql://construct:construct@localhost:5432/construct
REDIS_URL=redis://localhost:6379

# Claude API (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...
# Exact model id — see https://platform.claude.com/docs/en/about-claude/models/overview
CLAUDE_MODEL=claude-sonnet-5
CLAUDE_MAX_TOKENS=16000
# Transient-error retries (429/5xx/connection), exponential backoff — handled
# by the Anthropic SDK; this caps them.
CLAUDE_MAX_RETRIES=3

# Context cap: how many recent submissions per task are sent to Claude.
SUBMISSION_HISTORY_LIMIT=10
# How many review jobs may run concurrently.
WORKER_CONCURRENCY=2

# S3-compatible object storage — same values as apps/api. The worker reads
# submission photos directly (server-side GetObject) to pass them to Claude
# as image content blocks.
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=construct-coordinator
S3_ACCESS_KEY_ID=change-me
S3_SECRET_ACCESS_KEY=change-me
S3_FORCE_PATH_STYLE=true
